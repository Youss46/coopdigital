# ── Base de données ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/coopdigital

# ── Auth JWT ──────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret

# ── CORS ─────────────────────────────────────────────────────────────────────
# Liste des origines autorisées séparées par des virgules.
# Laisser vide pour autoriser toutes les origines (déconseillé en production).
ALLOWED_ORIGINS=https://coopdigital.vercel.app,https://portail.vercel.app,https://m15.vercel.app

# ── Serveur ───────────────────────────────────────────────────────────────────
# Railway injecte PORT automatiquement — ne pas surcharger manuellement.
PORT=8080

# ── Stockage objet (optionnel) ────────────────────────────────────────────────
# DEFAULT_OBJECT_STORAGE_BUCKET_ID=
# PRIVATE_OBJECT_DIR=
# PUBLIC_OBJECT_SEARCH_PATHS=
