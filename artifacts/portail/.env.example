# URL de base de l'API Railway (sans slash final, sans /api)
# Laisser vide en développement local (utilise les chemins relatifs /api/...)
VITE_API_URL=https://votre-api.up.railway.app

# Clé publique VAPID (optionnel mais recommandé sur Vercel)
# Évite un appel API au démarrage pour récupérer la clé → abonnement push instantané
# Valeur : identique à VAPID_PUBLIC_KEY sur Railway
VITE_VAPID_PUBLIC_KEY=
